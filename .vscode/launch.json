{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask Application (Windows)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "run",
                "--host=0.0.0.0",
                "--port=5000",
                "--debug"
            ],
            "jinja": true,
            "justMyCode": true,
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv/Scripts/python.exe"
        },
        {
            "name": "Python: Flask Application (WSL)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "run",
                "--host=0.0.0.0",
                "--port=5000",
                "--debug"
            ],
            "jinja": true,
            "justMyCode": true,
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv/bin/python"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "python": "${workspaceFolder}/venv/Scripts/python.exe"
        },
        {
            "name": "Python: Test All",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}/tests",
                "-v",
                "--cov=.",
                "--cov-report=html",
                "--cov-report=term"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "python": "${workspaceFolder}/venv/Scripts/python.exe"
        },
        {
            "name": "Python: Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            }
        }
    ],
    "compounds": [
        {
            "name": "Flask + Debug (Windows)",
            "configurations": [
                "Python: Flask Application (Windows)"
            ]
        },
        {
            "name": "Flask + Debug (WSL)",
            "configurations": [
                "Python: Flask Application (WSL)"
            ]
        }
    ]
}